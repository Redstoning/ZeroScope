#!/usr/bin/env bash
set -euo pipefail

banner() {
cat << "EOF"

 ______                 _____                      
|___  /                /  ___|                     
   / /  ___ _ __ ___   \ `--.  ___ ___  _ __   ___ 
  / /  / _ \ '__/ _ \   `--. \/ __/ _ \| '_ \ / _ \
./ /__|  __/ | | (_) | /\__/ / (_| (_) | |_) |  __/
\_____/\___|_|  \___/  \____/ \___\___/| .__/ \___|
                                       | |         
                                       |_|         

                  Hack The Planet

EOF
}

banner

SCOPE=""
OUT=""
ACK=""
RESUME=0
CONCURRENCY="50"
RATE="10"
DEPTH="3"
WORDLIST="./wordlists/discovery.txt"
DO_NMAP=1
DO_FFUF=1
DO_NUCLEI=1
NUCLEI_TAGS="misconfig,cves,default-logins,exposed-panels,takeovers"
SEVERITY="low,medium,high,critical"

usage() {
  cat <<'EOF'
zeroscope - Authorized scope recon + triage (NO Python)

Required:
  --scope scope.txt
  --out outdir
  --ack I_HAVE_AUTHORIZATION

Optional:
  --resume
  --concurrency 50
  --rate 10
  --depth 3
  --wordlist path.txt
  --no-nmap
  --no-ffuf
  --no-nuclei
  --nuclei-tags "misconfig,cves,..."
  --severity "low,medium,high,critical"
EOF
}

need() { command -v "$1" >/dev/null 2>&1 || { echo "Missing dependency: $1"; exit 1; }; }
step_done() { [[ -f "$1" ]]; }
mark_done() { touch "$1"; }

while [[ $# -gt 0 ]]; do
  case "$1" in
    --scope) SCOPE="$2"; shift 2;;
    --out) OUT="$2"; shift 2;;
    --ack) ACK="$2"; shift 2;;
    --resume) RESUME=1; shift 1;;
    --concurrency) CONCURRENCY="$2"; shift 2;;
    --rate) RATE="$2"; shift 2;;
    --depth) DEPTH="$2"; shift 2;;
    --wordlist) WORDLIST="$2"; shift 2;;
    --no-nmap) DO_NMAP=0; shift 1;;
    --no-ffuf) DO_FFUF=0; shift 1;;
    --no-nuclei) DO_NUCLEI=0; shift 1;;
    --nuclei-tags) NUCLEI_TAGS="$2"; shift 2;;
    --severity) SEVERITY="$2"; shift 2;;
    -h|--help) usage; exit 0;;
    *) echo "Unknown arg: $1"; usage; exit 1;;
  esac
done

if [[ -z "$SCOPE" || -z "$OUT" || -z "$ACK" ]]; then usage; exit 1; fi
if [[ "$ACK" != "I_HAVE_AUTHORIZATION" ]]; then echo "Refusing to run without --ack I_HAVE_AUTHORIZATION"; exit 1; fi
if [[ ! -f "$SCOPE" ]]; then echo "Scope file not found: $SCOPE"; exit 1; fi

need jq
need rg
need subfinder
need dnsx
need httpx
need katana
need gau
need waybackurls
if [[ "$DO_NMAP" -eq 1 ]]; then need nmap; fi
if [[ "$DO_FFUF" -eq 1 ]]; then need ffuf; fi
if [[ "$DO_NUCLEI" -eq 1 ]]; then need nuclei; fi

mkdir -p "$OUT"
RUN="$OUT/run"
mkdir -p "$RUN/evidence" "$RUN/state" "$RUN/state/done"

DONE="$RUN/state/done"
touch "$RUN/state/seen_hosts.txt" "$RUN/state/seen_urls.txt" "$RUN/state/seen_params.txt"

normalize_scope() {
  cat "$SCOPE" \
    | sed 's/\r//g' \
    | sed 's#^https\?://##g' \
    | sed 's#/.*$##g' \
    | sed 's/[[:space:]]//g' \
    | sed '/^$/d' \
    | sed '/^#/d' \
    | tr 'A-Z' 'a-z' \
    | sort -u > "$RUN/scope.normalized.txt"
}

is_in_scope_host() {
  local h="$1"
  [[ -z "$h" ]] && return 1
  h="$(echo "$h" | tr 'A-Z' 'a-z')"
  if rg -qx "$h" "$RUN/scope.normalized.txt"; then return 0; fi
  while read -r root; do
    [[ -z "$root" ]] && continue
    if [[ "$h" == *".${root}" ]]; then return 0; fi
  done < "$RUN/scope.normalized.txt"
  return 1
}

filter_in_scope_hosts() {
  while read -r h; do
    [[ -z "$h" ]] && continue
    if is_in_scope_host "$h"; then echo "$h"; fi
  done
}

append_unique() {
  local src="$1"
  local dst="$2"
  [[ ! -f "$src" ]] && return 0
  cat "$src" | sed '/^$/d' | sort -u > "${src}.u"
  cat "$dst" "${src}.u" 2>/dev/null | sed '/^$/d' | sort -u > "${dst}.new"
  mv "${dst}.new" "$dst"
  rm -f "${src}.u"
}

safe_url_host() {
  echo "$1" | sed 's#^https\?://##g' | sed 's#/.*$##g' | tr '/:?' '___'
}

run_step() {
  local name="$1"
  local donefile="$DONE/$name"
  shift
  if [[ "$RESUME" -eq 1 ]] && step_done "$donefile"; then
    echo "[*] Skipping (resume): $name"
    return 0
  fi
  echo "[*] Running: $name"
  "$@"
  mark_done "$donefile"
}

normalize_scope

run_step "01_subfinder" bash -c '
  subfinder -silent -dL "'"$RUN"'/scope.normalized.txt" -all -o "'"$RUN"'/subs_raw.txt" || true
  cat "'"$RUN"'/scope.normalized.txt" "'"$RUN"'/subs_raw.txt" 2>/dev/null | sed "/^$/d" | sort -u > "'"$RUN"'/targets_raw.txt"
  cat "'"$RUN"'/targets_raw.txt" | filter_in_scope_hosts > "'"$RUN"'/targets.txt"
'

run_step "02_dnsx" bash -c '
  dnsx -silent -l "'"$RUN"'/targets.txt" -a -aaaa -resp -o "'"$RUN"'/resolved.txt" || true
  cut -d" " -f1 "'"$RUN"'/resolved.txt" | sed "/^$/d" | sort -u | filter_in_scope_hosts > "'"$RUN"'/resolved_hosts.txt"
  append_unique "'"$RUN"'/resolved_hosts.txt" "'"$RUN"'/state/seen_hosts.txt"
  cp -f "'"$RUN"'/state/seen_hosts.txt" "'"$RUN"'/hosts_all.txt"
'

run_step "03_httpx" bash -c '
  httpx -silent -l "'"$RUN"'/hosts_all.txt" -title -tech-detect -status-code -content-length -server -location \
    -threads "'"$CONCURRENCY"'" -rate-limit "'"$RATE"'" -json -o "'"$RUN"'/httpx.json" || true

  jq -r "select(.url!=null) | .url" "'"$RUN"'/httpx.json" 2>/dev/null | sed "/^$/d" | sort -u > "'"$RUN"'/live_urls_raw.txt"
  cat "'"$RUN"'/live_urls_raw.txt" | while read -r u; do
    h=$(echo "$u" | sed "s#^https\\?://##g" | sed "s#/.*$##g")
    if is_in_scope_host "$h"; then echo "$u"; fi
  done | sort -u > "'"$RUN"'/live_urls.txt"

  jq -r "select(.host!=null) | .host" "'"$RUN"'/httpx.json" 2>/dev/null | sed "/^$/d" | sort -u | filter_in_scope_hosts > "'"$RUN"'/live_hosts.txt"

  append_unique "'"$RUN"'/live_urls.txt" "'"$RUN"'/state/seen_urls.txt"
'

run_step "04_urls_historical" bash -c '
  cat "'"$RUN"'/live_hosts.txt" | gau --subs --blacklist png,jpg,jpeg,gif,svg,css,woff,woff2,eot,ttf,ico,mp4,mp3,pdf,zip,tar,gz,7z 2>/dev/null \
    | sed "/^$/d" | sort -u > "'"$RUN"'/gau_urls.txt" || true

  cat "'"$RUN"'/live_hosts.txt" | waybackurls 2>/dev/null | sed "/^$/d" | sort -u > "'"$RUN"'/wayback_urls.txt" || true

  cat "'"$RUN"'/gau_urls.txt" "'"$RUN"'/wayback_urls.txt" 2>/dev/null | sed "/^$/d" | sort -u > "'"$RUN"'/urls_hist_raw.txt" || true

  cat "'"$RUN"'/urls_hist_raw.txt" | while read -r u; do
    h=$(echo "$u" | sed "s#^https\\?://##g" | sed "s#/.*$##g")
    if is_in_scope_host "$h"; then echo "$u"; fi
  done | sort -u > "'"$RUN"'/urls_hist.txt"

  append_unique "'"$RUN"'/urls_hist.txt" "'"$RUN"'/state/seen_urls.txt"
'

run_step "05_katana" bash -c '
  katana -silent -list "'"$RUN"'/live_urls.txt" -depth "'"$DEPTH"'" -jc -jsl -kf -c "'"$CONCURRENCY"'" -rl "'"$RATE"'" \
    -o "'"$RUN"'/katana_urls_raw.txt" || true

  cat "'"$RUN"'/katana_urls_raw.txt" | while read -r u; do
    h=$(echo "$u" | sed "s#^https\\?://##g" | sed "s#/.*$##g")
    if is_in_scope_host "$h"; then echo "$u"; fi
  done | sed "/^$/d" | sort -u > "'"$RUN"'/katana_urls.txt"

  append_unique "'"$RUN"'/katana_urls.txt" "'"$RUN"'/state/seen_urls.txt"
'

run_step "06_params" bash -c '
  cp -f "'"$RUN"'/state/seen_urls.txt" "'"$RUN"'/urls_merged.txt"
  rg -n "\\?" "'"$RUN"'/urls_merged.txt" | cut -d: -f2- | sed "/^$/d" | sort -u > "'"$RUN"'/urls_params_new.txt" || true
  append_unique "'"$RUN"'/urls_params_new.txt" "'"$RUN"'/state/seen_params.txt"
  cp -f "'"$RUN"'/state/seen_params.txt" "'"$RUN"'/urls_params_all.txt"
'

if [[ "$DO_NMAP" -eq 1 ]]; then
  run_step "07_nmap_top200" bash -c '
    nmap -sV -sC -T4 --top-ports 200 -iL "'"$RUN"'/live_hosts.txt" -oN "'"$RUN"'/evidence/nmap_top200.txt" || true
  '
fi

if [[ "$DO_FFUF" -eq 1 ]]; then
  if [[ ! -f "$WORDLIST" ]]; then echo "Wordlist not found: $WORDLIST"; exit 1; fi
  run_step "08_ffuf_light" bash -c '
    mkdir -p "'"$RUN"'/evidence/ffuf"
    while read -r u; do
      [[ -z "$u" ]] && continue
      hs=$(safe_url_host "$u")
      ffuf -w "'"$WORDLIST"'" -u "$u/FUZZ" -t 30 -rate "'"$RATE"'" -timeout 8 \
        -mc 200,204,301,302,307,308,401,403,405 -of json -o "'"$RUN"'/evidence/ffuf/${hs}.json" >/dev/null 2>&1 || true
    done < "'"$RUN"'/live_urls.txt"
  '
fi

if [[ "$DO_NUCLEI" -eq 1 ]]; then
  run_step "09_nuclei" bash -c '
    nuclei -silent -l "'"$RUN"'/live_urls.txt" -tags "'"$NUCLEI_TAGS"'" -severity "'"$SEVERITY"'" \
      -rl "'"$RATE"'" -c "'"$CONCURRENCY"'" -jsonl -o "'"$RUN"'/evidence/nuclei.jsonl" || true
  '
fi

run_step "10_rank" bash -c '
  jq -r "
    select(.host!=null) |
    [
      .host,
      (.url // \"\"),
      (.status_code // 0),
      (.title // \"\" | gsub(\"\\t\";\" \") | .[0:120]),
      ((.tech // []) | join(\",\")),
      ((.webserver // .server // \"\") | tostring)
    ] | @tsv
  " "'"$RUN"'/httpx.json" 2>/dev/null \
  | awk -F"\t" '
    function sc(status, tech, server, s, tl) {
      s=0
      if (status==200 || status==204) s+=3
      if (status==401 || status==403) s+=5
      if (status>=500 && status<600) s+=8
      if (server!="") s+=2
      if (tech!="") s+=2
      tl=tolower(tech)
      if (tl ~ /(graphql|kibana|jenkins|gitlab|jira|confluence|harbor|vault|traefik|kong)/) s+=8
      return s
    }
    {
      host=$1; url=$2; status=$3+0; title=$4; tech=$5; server=$6
      score=sc(status,tech,server)
      print score "\t" host "\t" url "\t" status "\t" title "\t" tech "\t" server
    }
  ' | sort -rn -k1,1 > "'"$RUN"'/ranked.tsv"
'

run_step "11_report_md" bash -c '
  report="'"$RUN"'/REPORT.md"
  {
    echo "# ZeroScope Report"
    echo
    echo "- Run directory: run/"
    echo "- Generated: $(date -Is)"
    echo
    echo "## Files"
    echo "- live_urls.txt"
    echo "- live_hosts.txt"
    echo "- urls_merged.txt"
    echo "- urls_params_all.txt"
    echo "- ranked.tsv"
    echo "- evidence/"
    echo
    echo "## Top Targets"
    echo
    echo "| Score | Host | URL | Status | Title |"
    echo "|---:|---|---|---:|---|"
    head -n 50 "'"$RUN"'/ranked.tsv" | awk -F"\t" "{print \"| \"$1\" | \"$2\" | \"$3\" | \"$4\" | \"$5\" |\"}"
    echo
    echo "## Per-Host"
    echo
  } > "$report"

  cut -f2 "'"$RUN"'/ranked.tsv" | head -n 80 | while read -r host; do
    [[ -z "$host" ]] && continue
    url=$(awk -F"\t" -v h="$host" "$2==h {print $3; exit}" "'"$RUN"'/ranked.tsv")
    status=$(awk -F"\t" -v h="$host" "$2==h {print $4; exit}" "'"$RUN"'/ranked.tsv")
    title=$(awk -F"\t" -v h="$host" "$2==h {print $5; exit}" "'"$RUN"'/ranked.tsv")
    tech=$(awk -F"\t" -v h="$host" "$2==h {print $6; exit}" "'"$RUN"'/ranked.tsv")
    server=$(awk -F"\t" -v h="$host" "$2==h {print $7; exit}" "'"$RUN"'/ranked.tsv")

    {
      echo "### $host"
      echo
      echo "- URL: $url"
      echo "- Status: $status"
      echo "- Title: $title"
      echo "- Tech: $tech"
      echo "- Server: $server"
      echo
      echo "**Evidence**"
      echo
      echo "- httpx.json (filter): \`jq -c \"select(.host==\\\"$host\\\")\" httpx.json\`"
      [[ -f "'"$RUN"'/evidence/nmap_top200.txt" ]] && echo "- nmap: evidence/nmap_top200.txt"
      [[ -f "'"$RUN"'/evidence/nuclei.jsonl" ]] && echo "- nuclei: evidence/nuclei.jsonl"
      [[ -d "'"$RUN"'/evidence/ffuf" ]] && echo "- ffuf: evidence/ffuf/"
      echo
      echo "**Next manual checks**"
      echo "- Review urls_params_all.txt entries for this host."
      echo "- Verify auth boundaries, IDOR patterns, and error leakage."
      echo
    } >> "$report"
  done
'

echo "[*] Done"
echo "Run directory: $RUN"
echo "Report: $RUN/REPORT.md"
echo "Key outputs:"
echo "  $RUN/live_urls.txt"
echo "  $RUN/urls_params_all.txt"
echo "  $RUN/ranked.tsv"
echo "  $RUN/evidence/"