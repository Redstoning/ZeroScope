    printf "\n%s> %s" "$C_BOLD" "$C_RESET"
    IFS= read -r c || true
    c="$(trim "$c")"
    case "$c" in
      r|R) DO_RANK=1; DO_REPORT=1; printf "%s[+]%s Added\n" "$C_GREEN" "$C_RESET"; pause; return 0 ;;
      b|B) return 0 ;;
      *) ;;
    esac
  done
}

selected_summary(){
  local s=""
  [[ "$DO_RECON" -eq 1 ]] && s="$s recon"
  [[ "$DO_URLS" -eq 1 ]] && s="$s urls"
  [[ "$DO_CRAWL" -eq 1 ]] && s="$s crawl"
  [[ "$DO_PARAMS" -eq 1 ]] && s="$s params"
  [[ "$DO_NUCLEI" -eq 1 ]] && s="$s nuclei"
  [[ "$DO_FFUF" -eq 1 ]] && s="$s ffuf"
  [[ "$DO_NMAP" -eq 1 ]] && s="$s nmap"
  [[ "$DO_REPORT" -eq 1 ]] && s="$s report"
  s="$(trim "$s")"
  [[ -z "$s" ]] && s="<none>"
  printf "%s" "$s"
}

generate_runbook(){
  if [[ "$(targets_count)" -eq 0 ]]; then
    printf "\n%s[!]%s Add targets first.\n" "$C_YELLOW" "$C_RESET"
    pause
    return 1
  fi
  if ! auth_gate; then
    return 0
  fi

  local cmds="$RUN/COMMANDS.sh"
  local rep="$RUN/REPORT.md"
  local now
  now="$(date -Is)"

  {
    echo "#!/usr/bin/env bash"
    echo "set -euo pipefail"
    echo "OUTDIR=\"$RUN\""
    echo "TARGETS=\"$TARGETS\""
    echo "RATE=\"$RATE\""
    echo "THREADS=\"$THREADS\""
    echo "DEPTH=\"$DEPTH\""
    echo "WORDLIST=\"$WORDLIST\""
    echo "NUCLEI_TAGS=\"$NUCLEI_TAGS\""
    echo "SEVERITY=\"$SEVERITY\""
    echo "mkdir -p \"\$OUTDIR/evidence\""
    echo "echo \"[runbook] generated: $now\""
    echo "echo \"[runbook] targets: \$TARGETS\""
    echo
    echo "echo \"[NOTE] This runbook is generated from UI selections.\""
    echo "echo \"[NOTE] Review commands before running.\""
    echo
    if [[ "$DO_RECON" -eq 1 ]]; then
      echo "echo \"[recon] (placeholder)\""
      echo "echo \"recon steps would go here\""
      echo
    fi
    if [[ "$DO_URLS" -eq 1 ]]; then
      echo "echo \"[urls] (placeholder)\""
      echo "echo \"url discovery steps would go here\""
      echo
    fi
    if [[ "$DO_CRAWL" -eq 1 ]]; then
      echo "echo \"[crawl] (placeholder)\""
      echo "echo \"crawl steps would go here\""
      echo
    fi
    if [[ "$DO_PARAMS" -eq 1 ]]; then
      echo "echo \"[params] (placeholder)\""
      echo "echo \"param extraction steps would go here\""
      echo
    fi
    if [[ "$DO_NUCLEI" -eq 1 ]]; then
      echo "echo \"[nuclei] (placeholder)\""
      echo "echo \"nuclei invocation would go here\""
      echo
    fi
    if [[ "$DO_FFUF" -eq 1 ]]; then
      echo "echo \"[ffuf] (placeholder)\""
      echo "echo \"ffuf invocation would go here\""
      echo
    fi
    if [[ "$DO_NMAP" -eq 1 ]]; then
      echo "echo \"[nmap] (placeholder)\""
      echo "echo \"nmap invocation would go here\""
      echo
    fi
    if [[ "$DO_REPORT" -eq 1 ]]; then
      echo "echo \"[report] (placeholder)\""
      echo "echo \"report steps would go here\""
      echo
    fi
    echo "echo \"[done]\""
  } > "$cmds"
  chmod +x "$cmds"

  {
    echo "# ZeroScope Report"
    echo
    echo "- Generated: $now"
    echo "- Targets file: $TARGETS"
    echo "- Selected: $(selected_summary)"
    echo
    echo "## Evidence"
    echo "- out/run/evidence/"
    echo
    echo "## Notes"
    echo "- Review COMMANDS.sh before running."
  } > "$rep"

  {
    echo "Generated: $now"
    echo "Authorization phrase accepted."
    echo "Selected: $(selected_summary)"
    echo "Targets:"
    cat "$TARGETS"
  } > "$RUN/AUTHORIZATION.txt"

  printf "\n%s[+]%s Generated:\n" "$C_GREEN" "$C_RESET"
  printf "  %s\n" "$cmds"
  printf "  %s\n" "$rep"
  pause
}

modules_menu(){
  while true; do
    banner
    status_panel
    box_top
    box_ln "${C_BOLD}Modules${C_RESET}"
    box_ln ""
    box_ln "${C_YELLOW}1${C_RESET}) Recon"
    box_ln "${C_YELLOW}2${C_RESET}) URL Discovery"
    box_ln "${C_YELLOW}3${C_RESET}) Crawl"
    box_ln "${C_YELLOW}4${C_RESET}) Params"
    box_ln "${C_YELLOW}5${C_RESET}) Scans"
    box_ln "${C_YELLOW}6${C_RESET}) Report"
    box_ln ""
    box_ln "${C_YELLOW}c${C_RESET}) Clear selection"
    box_ln "${C_YELLOW}g${C_RESET}) Generate runbook"
    box_ln "${C_YELLOW}b${C_RESET}) Back"
    box_bot

    printf "\n%sSelected:%s %s\n" "$C_DIM" "$C_RESET" "$(selected_summary)"
    printf "\n%s> %s" "$C_BOLD" "$C_RESET"
    IFS= read -r c || true
    c="$(trim "$c")"
    case "$c" in
      1) page_recon ;;
      2) page_urls ;;
      3) page_crawl ;;
      4) page_params ;;
      5) page_scan ;;
      6) page_report ;;
      c|C) reset_modules; printf "\n%s[+]%s Cleared\n" "$C_GREEN" "$C_RESET"; pause ;;
      g|G) generate_runbook ;;
      b|B) return 0 ;;
      *) ;;
    esac
  done
}

main_menu(){
  init_run
  reset_modules
  while true; do
    banner
    status_panel
    box_top
    box_ln "${C_BOLD}ZeroScope${C_RESET}"
    box_ln ""
    box_ln "${C_YELLOW}1${C_RESET}) Targets"
    box_ln "${C_YELLOW}2${C_RESET}) Modules"
    box_ln "${C_YELLOW}3${C_RESET}) Settings"
    box_ln "${C_YELLOW}4${C_RESET}) Doctor"
    box_ln ""
    box_ln "${C_YELLOW}q${C_RESET}) Quit"
    box_bot
    printf "\n%s> %s" "$C_BOLD" "$C_RESET"
    IFS= read -r c || true
    c="$(trim "$c")"
    case "$c" in
      1) targets_menu ;;
      2) modules_menu ;;
      3) settings_menu ;;
      4) doctor_menu ;;
      q|Q) exit 0 ;;
      *) ;;
    esac
  done
}

main_menu
