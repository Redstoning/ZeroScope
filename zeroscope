    box_ln "${C_YELLOW}5${C_RESET}) Doctor"
    box_ln ""
    box_ln "${C_YELLOW}q${C_RESET}) Quit"
    box_bot
    printf "\n%s> %s" "$C_BOLD" "$C_RESET"
    IFS= read -r c || true
    c="$(trim "$c")"
    case "$c" in
      1) targets_menu ;;
      2) modules_menu ;;
      3) module_config_menu ;;
      4) settings_menu ;;
      5) doctor_menu ;;
      q|Q) exit 0 ;;
      *) ;;
    esac
  done
}

