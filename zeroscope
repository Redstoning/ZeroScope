#!/usr/bin/env bash
set -euo pipefail

if command -v tput >/dev/null 2>&1; then
  C_RESET="$(tput sgr0)"; C_BOLD="$(tput bold)"; C_DIM="$(tput dim)"
  C_RED="$(tput setaf 1)"; C_GREEN="$(tput setaf 2)"; C_YELLOW="$(tput setaf 3)"
  C_BLUE="$(tput setaf 4)"; C_MAGENTA="$(tput setaf 5)"; C_CYAN="$(tput setaf 6)"; C_WHITE="$(tput setaf 7)"
else
  C_RESET=""; C_BOLD=""; C_DIM=""
  C_RED=""; C_GREEN=""; C_YELLOW=""; C_BLUE=""; C_MAGENTA=""; C_CYAN=""; C_WHITE=""
fi

cls(){ printf "\033c"; }
pause(){ printf "\n%sPress Enter...%s" "$C_DIM" "$C_RESET"; IFS= read -r _; }
trim(){ printf "%s" "$1" | sed 's/\r//g' | sed 's/^[[:space:]]\+//; s/[[:space:]]\+$//'; }
lower(){ printf "%s" "$1" | tr 'A-Z' 'a-z'; }
need(){ command -v "$1" >/dev/null 2>&1; }

W="$(tput cols 2>/dev/null || echo 80)"
W=$((W-6))
if (( W < 52 )); then W=52; fi
if (( W > 96 )); then W=96; fi
line(){ printf "%s" "$(printf '─%.0s' $(seq 1 "$W"))"; }
box_top(){ printf "%s┌%s┐%s\n" "$C_MAGENTA" "$(line)" "$C_RESET"; }
box_bot(){ printf "%s└%s┘%s\n" "$C_MAGENTA" "$(line)" "$C_RESET"; }
box_ln(){ printf "%s│%s %-*s %s│%s\n" "$C_MAGENTA" "$C_RESET" "$W" "$1" "$C_MAGENTA" "$C_RESET"; }

banner(){
  cls
  cat <<'EOF'

 ______                 _____                      
|___  /                /  ___|                     
   / /  ___ _ __ ___   \ `--.  ___ ___  _ __   ___ 
  / /  / _ \ '__/ _ \   `--. \/ __/ _ \| '_ \ / _ \
./ /__|  __/ | | (_) | /\__/ / (_| (_) | |_) |  __/
\_____/\___|_|  \___/  \____/ \___\___/| .__/ \___|
                                       | |         
                                       |_|         

                  Hack The Planet

EOF
}

OUT="out"
RUN=""
STATE=""
DONE=""
EVID=""
TARGETS=""
AUTH_PHRASE="I_HAVE_AUTHORIZATION"

WORDLIST=""
RATE="10"
THREADS="50"
DEPTH="3"
NUCLEI_TAGS="misconfig,cves,default-logins,exposed-panels,takeovers"
SEVERITY="low,medium,high,critical"

init_run(){
  mkdir -p "$OUT/run"
  RUN="$OUT/run"
  STATE="$RUN/state"
  DONE="$STATE/done"
  EVID="$RUN/evidence"
  mkdir -p "$STATE" "$DONE" "$EVID"
  TARGETS="$RUN/targets.txt"
  touch "$TARGETS"
}

normalize_target(){
  local x
  x="$(trim "$1")"
  x="$(printf "%s" "$x" | sed 's#^https\?://##g' | sed 's#/.*$##g' | sed 's/[[:space:]]//g')"
  x="$(lower "$x")"
  printf "%s" "$x"
}

targets_count(){ grep -c "." "$TARGETS" 2>/dev/null || echo 0; }

show_targets(){
  echo
  if [[ -s "$TARGETS" ]]; then
    nl -ba "$TARGETS"
  else
    echo "No targets saved."
  fi
}

targets_add(){
  echo
  echo "${C_DIM}Paste targets one per line. Blank line = finish. done = finish. b = back.${C_RESET}"
  echo
  while true; do
    printf "> "
    IFS= read -r line || true
    line="$(trim "$line")"
    local l
    l="$(lower "$line")"
    [[ "$l" == "b" ]] && return 0
    [[ -z "$line" ]] && break
    [[ "$l" == "done" ]] && break
    local t
    t="$(normalize_target "$line")"
    [[ -z "$t" ]] && continue
    echo "$t" >> "$TARGETS"
    printf "%s[+]%s %s\n" "$C_GREEN" "$C_RESET" "$t"
  done
  sort -u "$TARGETS" -o "$TARGETS"
  echo
  printf "%s[+]%s Saved: %s targets\n" "$C_GREEN" "$C_RESET" "$(targets_count)"
  show_targets
  echo
  pause
}

targets_clear(){
  : > "$TARGETS"
  printf "\n%s[+]%s Targets cleared\n" "$C_GREEN" "$C_RESET"
  pause
}

targets_menu(){
  while true; do
    banner
    box_top
    box_ln "${C_BOLD}Targets${C_RESET}"
    box_ln ""
    box_ln "Stored automatically in: ${C_CYAN}${TARGETS}${C_RESET}"
    box_ln ""
    box_ln "${C_YELLOW}1${C_RESET}) Add targets"
    box_ln "${C_YELLOW}2${C_RESET}) View targets"
    box_ln "${C_YELLOW}3${C_RESET}) Clear targets"
    box_ln "${C_YELLOW}b${C_RESET}) Back"
    box_bot
    printf "\n%sTargets:%s %s\n" "$C_DIM" "$C_RESET" "$(targets_count)"
    printf "\n%s> %s" "$C_BOLD" "$C_RESET"
    IFS= read -r c || true
    c="$(trim "$c")"
    case "$c" in
      1) targets_add ;;
      2) show_targets; echo; pause ;;
      3) targets_clear ;;
      b|B) return 0 ;;
      *) ;;
    esac
  done
}

settings_menu(){
  while true; do
    banner
    box_top
    box_ln "${C_BOLD}Settings${C_RESET}"
    box_ln ""
    box_ln "Out: ${C_CYAN}${OUT}${C_RESET}"
    box_ln "Rate: ${C_CYAN}${RATE}${C_RESET}   Threads: ${C_CYAN}${THREADS}${C_RESET}   Depth: ${C_CYAN}${DEPTH}${C_RESET}"
    box_ln "Wordlist: ${C_CYAN}${WORDLIST:-<unset>}${C_RESET}"
    box_ln "Nuclei tags: ${C_CYAN}${NUCLEI_TAGS}${C_RESET}"
    box_ln "Severity: ${C_CYAN}${SEVERITY}${C_RESET}"
    box_ln ""
    box_ln "${C_YELLOW}1${C_RESET}) Output directory"
    box_ln "${C_YELLOW}2${C_RESET}) Rate limit"
    box_ln "${C_YELLOW}3${C_RESET}) Threads"
    box_ln "${C_YELLOW}4${C_RESET}) Crawl depth"
    box_ln "${C_YELLOW}5${C_RESET}) Wordlist path"
    box_ln "${C_YELLOW}6${C_RESET}) Nuclei tags"
    box_ln "${C_YELLOW}7${C_RESET}) Nuclei severity"
    box_ln "${C_YELLOW}b${C_RESET}) Back"
    box_bot
    printf "\n%s> %s" "$C_BOLD" "$C_RESET"
    IFS= read -r c || true
    c="$(trim "$c")"
    case "$c" in
      1) printf "Out [%s]: " "$OUT"; IFS= read -r v || true; v="$(trim "$v")"; [[ -n "$v" ]] && OUT="$v"; init_run ;;
      2) printf "Rate [%s]: " "$RATE"; IFS= read -r v || true; v="$(trim "$v")"; [[ -n "$v" ]] && RATE="$v" ;;
      3) printf "Threads [%s]: " "$THREADS"; IFS= read -r v || true; v="$(trim "$v")"; [[ -n "$v" ]] && THREADS="$v" ;;
      4) printf "Depth [%s]: " "$DEPTH"; IFS= read -r v || true; v="$(trim "$v")"; [[ -n "$v" ]] && DEPTH="$v" ;;
      5) printf "Wordlist (blank unset): "; IFS= read -r v || true; WORDLIST="$(trim "$v")" ;;
      6) printf "Nuclei tags [%s]: " "$NUCLEI_TAGS"; IFS= read -r v || true; v="$(trim "$v")"; [[ -n "$v" ]] && NUCLEI_TAGS="$v" ;;
      7) printf "Severity [%s]: " "$SEVERITY"; IFS= read -r v || true; v="$(trim "$v")"; [[ -n "$v" ]] && SEVERITY="$v" ;;
      b|B) return 0 ;;
      *) ;;
    esac
  done
}

doctor_menu(){
  banner
  box_top
  box_ln "${C_BOLD}Doctor${C_RESET}"
  box_ln ""
  box_ln "Dependency presence (optional)."
  box_ln ""
  box_bot
  echo
  for c in bash sed awk grep sort nl tput; do
    if need "$c"; then
      printf "%sOK%s   %s\n" "$C_GREEN" "$C_RESET" "$c"
    else
      printf "%sMISS%s %s\n" "$C_RED" "$C_RESET" "$c"
    fi
  done
  echo
  echo "${C_DIM}Your modules can require additional tools. Add checks inside module bodies.${C_RESET}"
  pause
}

status_panel(){
  box_top
  box_ln "${C_BOLD}Session${C_RESET}"
  box_ln ""
  box_ln "Targets: ${C_CYAN}$(targets_count)${C_RESET}   Out: ${C_CYAN}${OUT}${C_RESET}"
  box_ln "Rate: ${C_CYAN}${RATE}${C_RESET}  Threads: ${C_CYAN}${THREADS}${C_RESET}  Depth: ${C_CYAN}${DEPTH}${C_RESET}"
  box_ln ""
  box_bot
}

auth_gate(){
  banner
  status_panel
  box_top
  box_ln "${C_BOLD}Authorization Gate${C_RESET}"
  box_ln ""
  box_ln "Type the phrase exactly to proceed:"
  box_ln "  ${C_CYAN}${AUTH_PHRASE}${C_RESET}"
  box_ln ""
  box_ln "${C_YELLOW}b${C_RESET}) Back"
  box_bot
  printf "\n%s> %s" "$C_BOLD" "$C_RESET"
  IFS= read -r a || true
  a="$(trim "$a")"
  [[ "$(lower "$a")" == "b" ]] && return 1
  [[ "$a" == "$AUTH_PHRASE" ]]
}

mark_done(){ touch "$DONE/$1.done"; }
is_done(){ [[ -f "$DONE/$1.done" ]]; }

write_auth_log(){
  local now
  now="$(date -Is)"
  {
    echo "Generated: $now"
    echo "Authorization phrase accepted."
    echo "Targets:"
    cat "$TARGETS"
  } > "$RUN/AUTHORIZATION.txt"
}

ensure_report(){
  local rep="$RUN/REPORT.md"
  if [[ ! -f "$rep" ]]; then
    {
      echo "# ZeroScope Report"
      echo
      echo "## Targets"
      echo
      if [[ -s "$TARGETS" ]]; then
        while read -r t; do
          [[ -z "$t" ]] && continue
          echo "- $t"
        done < "$TARGETS"
      else
        echo "- (none)"
      fi
      echo
      echo "## Evidence Index"
      echo
      echo "- evidence/ (module outputs)"
      echo
      echo "## Hosts"
      echo
      if [[ -s "$TARGETS" ]]; then
        while read -r t; do
          [[ -z "$t" ]] && continue
          echo "### $t"
          echo
          echo "- Evidence:"
          echo "  - $(printf '%q\n' "evidence/$t/")"
          echo
        done < "$TARGETS"
      fi
    } > "$rep"
  fi
}

ensure_host_evidence_dirs(){
  if [[ -s "$TARGETS" ]]; then
    while read -r t; do
      [[ -z "$t" ]] && continue
      mkdir -p "$EVID/$t"
    done < "$TARGETS"
  fi
}

module_placeholder_run(){
  local mod="$1"
  local title="$2"
  local outdir="$3"

  mkdir -p "$outdir"
  local now
  now="$(date -Is)"
  {
    echo "Module: $mod"
    echo "Title: $title"
    echo "Time: $now"
    echo
    echo "This is a placeholder module."
    echo "Fill in this module body inside zeroscope to run your authorized toolchain."
  } > "$outdir/README.txt"
}

run_module(){
  local key="$1"
  local title="$2"

  if is_done "$key"; then
    printf "%s[skip]%s %s (resume)\n" "$C_DIM" "$C_RESET" "$title"
    return 0
  fi

  printf "%s[run]%s  %s\n" "$C_CYAN" "$C_RESET" "$title"
  local outdir="$EVID/_$key"
  case "$key" in
    recon) module_placeholder_run "$key" "$title" "$outdir" ;;
    urls) module_placeholder_run "$key" "$title" "$outdir" ;;
    crawl) module_placeholder_run "$key" "$title" "$outdir" ;;
    params) module_placeholder_run "$key" "$title" "$outdir" ;;
    nuclei) module_placeholder_run "$key" "$title" "$outdir" ;;
    ffuf) module_placeholder_run "$key" "$title" "$outdir" ;;
    nmap) module_placeholder_run "$key" "$title" "$outdir" ;;
    report)
      ensure_report
      module_placeholder_run "$key" "$title" "$outdir"
      ;;
    *) module_placeholder_run "$key" "$title" "$outdir" ;;
  esac
  mark_done "$key"
}

reset_selection(){
  SEL_recon=0
  SEL_urls=0
  SEL_crawl=0
  SEL_params=0
  SEL_nuclei=0
  SEL_ffuf=0
  SEL_nmap=0
  SEL_report=0
}

toggle(){
  local name="$1"
  local v="${!name}"
  if [[ "$v" -eq 1 ]]; then
    printf -v "$name" "0"
  else
    printf -v "$name" "1"
  fi
}

sel_mark(){
  local v="$1"
  if [[ "$v" -eq 1 ]]; then
    printf "%s[x]%s" "$C_GREEN" "$C_RESET"
  else
    printf "%s[ ]%s" "$C_DIM" "$C_RESET"
  fi
}

sel_summary(){
  local s=""
  [[ "$SEL_recon" -eq 1 ]] && s="$s recon"
  [[ "$SEL_urls" -eq 1 ]] && s="$s urls"
  [[ "$SEL_crawl" -eq 1 ]] && s="$s crawl"
  [[ "$SEL_params" -eq 1 ]] && s="$s params"
  [[ "$SEL_nuclei" -eq 1 ]] && s="$s nuclei"
  [[ "$SEL_ffuf" -eq 1 ]] && s="$s ffuf"
  [[ "$SEL_nmap" -eq 1 ]] && s="$s nmap"
  [[ "$SEL_report" -eq 1 ]] && s="$s report"
  s="$(trim "$s")"
  [[ -z "$s" ]] && s="<none>"
  printf "%s" "$s"
}

run_selected(){
  if [[ "$(targets_count)" -eq 0 ]]; then
    printf "\n%s[!]%s Add targets first.\n" "$C_YELLOW" "$C_RESET"
    pause
    return 1
  fi
  if [[ "$(sel_summary)" == "<none>" ]]; then
    printf "\n%s[!]%s Select at least one module.\n" "$C_YELLOW" "$C_RESET"
    pause
    return 1
  fi
  if ! auth_gate; then
    return 0
  fi

  mkdir -p "$EVID"
  ensure_host_evidence_dirs
  ensure_report
  write_auth_log

  banner
  status_panel
  box_top
  box_ln "${C_BOLD}Running Selected Modules${C_RESET}"
  box_ln ""
  box_ln "Resume is ON. Completed modules will be skipped."
  box_ln "Selected: $(sel_summary)"
  box_ln ""
  box_bot
  echo

  [[ "$SEL_recon" -eq 1 ]] && run_module "recon" "Recon (placeholder)"
  [[ "$SEL_urls" -eq 1 ]] && run_module "urls" "URL Discovery (placeholder)"
  [[ "$SEL_crawl" -eq 1 ]] && run_module "crawl" "Crawl (placeholder)"
  [[ "$SEL_params" -eq 1 ]] && run_module "params" "Params (placeholder)"
  [[ "$SEL_nuclei" -eq 1 ]] && run_module "nuclei" "Nuclei (placeholder)"
  [[ "$SEL_ffuf" -eq 1 ]] && run_module "ffuf" "ffuf (placeholder)"
  [[ "$SEL_nmap" -eq 1 ]] && run_module "nmap" "nmap (placeholder)"
  [[ "$SEL_report" -eq 1 ]] && run_module "report" "Report (placeholder)"

  echo
  printf "%s[+]%s Done.\n" "$C_GREEN" "$C_RESET"
  printf "%sReport:%s %s\n" "$C_DIM" "$C_RESET" "$RUN/REPORT.md"
  printf "%sEvidence:%s %s\n" "$C_DIM" "$C_RESET" "$RUN/evidence/"
  pause
}

modules_menu(){
  while true; do
    banner
    status_panel
    box_top
    box_ln "${C_BOLD}Modules${C_RESET}"
    box_ln ""
    box_ln "1) $(sel_mark "$SEL_recon") Recon"
    box_ln "2) $(sel_mark "$SEL_urls") URL Discovery"
    box_ln "3) $(sel_mark "$SEL_crawl") Crawl"
    box_ln "4) $(sel_mark "$SEL_params") Params"
    box_ln "5) $(sel_mark "$SEL_nuclei") Nuclei"
    box_ln "6) $(sel_mark "$SEL_ffuf") ffuf"
    box_ln "7) $(sel_mark "$SEL_nmap") nmap"
    box_ln "8) $(sel_mark "$SEL_report") Report"
    box_ln ""
    box_ln "${C_YELLOW}r${C_RESET}) Run selected"
    box_ln "${C_YELLOW}c${C_RESET}) Clear selection"
    box_ln "${C_YELLOW}x${C_RESET}) Reset resume state"
    box_ln "${C_YELLOW}b${C_RESET}) Back"
    box_bot

    printf "\n%sSelected:%s %s\n" "$C_DIM" "$C_RESET" "$(sel_summary)"
    printf "\n%s> %s" "$C_BOLD" "$C_RESET"
    IFS= read -r c || true
    c="$(trim "$c")"
    case "$c" in
      1) toggle SEL_recon ;;
      2) toggle SEL_urls ;;
      3) toggle SEL_crawl ;;
      4) toggle SEL_params ;;
      5) toggle SEL_nuclei ;;
      6) toggle SEL_ffuf ;;
      7) toggle SEL_nmap ;;
      8) toggle SEL_report ;;
      r|R) run_selected ;;
      c|C) reset_selection ;;
      x|X) rm -f "$DONE/"*.done 2>/dev/null || true; printf "\n%s[+]%s Resume state reset.\n" "$C_GREEN" "$C_RESET"; pause ;;
      b|B) return 0 ;;
      *) ;;
    esac
  done
}

main_menu(){
  init_run
  reset_selection
  while true; do
    banner
    status_panel
    box_top
    box_ln "${C_BOLD}ZeroScope${C_RESET}"
    box_ln ""
    box_ln "${C_YELLOW}1${C_RESET}) Targets"
    box_ln "${C_YELLOW}2${C_RESET}) Modules"
    box_ln "${C_YELLOW}3${C_RESET}) Settings"
    box_ln "${C_YELLOW}4${C_RESET}) Doctor"
    box_ln ""
    box_ln "${C_YELLOW}q${C_RESET}) Quit"
    box_bot
    printf "\n%s> %s" "$C_BOLD" "$C_RESET"
    IFS= read -r c || true
    c="$(trim "$c")"
    case "$c" in
      1) targets_menu ;;
      2) modules_menu ;;
      3) settings_menu ;;
      4) doctor_menu ;;
      q|Q) exit 0 ;;
      *) ;;
    esac
  done
}

main_menu
