}

# ---------- Ethics Gate ----------
ethics_gate(){
  banner
  status_panel
  box_top
  box_ln "${C_BOLD}Ethics Gate${C_RESET}"
  box_ln ""
  while IFS= read -r l; do
    box_ln "$l"
  done <<<"$AUTH_GATE_TEXT"
  box_ln ""
  box_ln "Type ${C_CYAN}yes${C_RESET} to continue, or ${C_YELLOW}b${C_RESET} to go back."
  box_bot

  printf "\n%s> %s" "$C_BOLD" "$C_RESET"
  IFS= read -r a || true
  a="$(trim "$a")"
  [[ "$(lower "$a")" == "b" ]] && return 1
  [[ "$(lower "$a")" == "yes" ]]
}

# ---------- Resume markers ----------
mark_done(){ touch "$DONE/$1.done"; }
is_done(){ [[ -f "$DONE/$1.done" ]]; }
reset_resume(){
  rm -f "$DONE/"*.done 2>/dev/null || true
}

# ---------- modules.conf ----------
ensure_conf(){
  if [[ ! -f "$CONF" ]]; then
    cat >"$CONF" <<'EOF'
# ZeroScope modules.conf
# Define a command per module. Empty means "not configured".
# Variables you can use:
#   {TARGETS}  -> out/run/targets.txt
#   {OUT}      -> out/run
#   {EVID}     -> out/run/evidence
#   {LOGS}     -> out/run/logs
#   {WORDLIST} -> wordlist path (if set)
#   {RATE}     -> rate
#   {THREADS}  -> threads
#   {DEPTH}    -> depth
#
# Example (safe demo):
# RECON_CMD=echo "recon would run here"; sleep 1; echo "done"
#
RECON_CMD=
URLS_CMD=
CRAWL_CMD=
PARAMS_CMD=
FFUF_CMD=
NUCLEI_CMD=
NMAP_CMD=
REPORT_CMD=
EOF
  fi
}

conf_get(){
  local key="$1"
  local val=""
  if [[ -f "$CONF" ]]; then
    val="$(grep -E "^${key}=" "$CONF" 2>/dev/null | head -n1 | sed "s/^${key}=//")" || true
  fi
  printf "%s" "$val"
}

conf_set(){
  local key="$1"
  local value="$2"
  if grep -qE "^${key}=" "$CONF" 2>/dev/null; then
    awk -v k="$key" -v v="$value" 'BEGIN{FS=OFS="="} $1==k{$2=v} {print}' "$CONF" > "$CONF.tmp"
    mv "$CONF.tmp" "$CONF"
  else
    echo "${key}=${value}" >> "$CONF"
  fi
}

subst_vars(){
  local s="$1"
  s="${s//\{TARGETS\}/$TARGETS}"
  s="${s//\{OUT\}/$RUN}"
  s="${s//\{EVID\}/$EVID}"
  s="${s//\{LOGS\}/$LOGS}"
  s="${s//\{WORDLIST\}/$WORDLIST}"
  s="${s//\{RATE\}/$RATE}"
  s="${s//\{THREADS\}/$THREADS}"
  s="${s//\{DEPTH\}/$DEPTH}"
  printf "%s" "$s"
}

