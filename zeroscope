#!/usr/bin/env bash
set -euo pipefail

# ---------- UI ----------
if command -v tput >/dev/null 2>&1; then
  C_RESET="$(tput sgr0)"; C_BOLD="$(tput bold)"; C_DIM="$(tput dim)"
  C_RED="$(tput setaf 1)"; C_GREEN="$(tput setaf 2)"; C_YELLOW="$(tput setaf 3)"
  C_MAGENTA="$(tput setaf 5)"; C_CYAN="$(tput setaf 6)"
else
  C_RESET=""; C_BOLD=""; C_DIM=""
  C_RED=""; C_GREEN=""; C_YELLOW=""; C_MAGENTA=""; C_CYAN=""
fi

cls(){ printf "\033c"; }
pause(){ printf "\n%sPress Enter...%s" "$C_DIM" "$C_RESET"; IFS= read -r _ || true; }
trim(){ printf "%s" "$1" | sed 's/\r//g' | sed 's/^[[:space:]]\+//; s/[[:space:]]\+$//'; }
lower(){ printf "%s" "$1" | tr 'A-Z' 'a-z'; }
need(){ command -v "$1" >/dev/null 2>&1; }

W="$(tput cols 2>/dev/null || echo 80)"
W=$((W-6))
if (( W < 52 )); then W=52; fi
if (( W > 96 )); then W=96; fi
line(){ printf "%s" "$(printf '─%.0s' $(seq 1 "$W"))"; }
box_top(){ printf "%s┌%s┐%s\n" "$C_MAGENTA" "$(line)" "$C_RESET"; }
box_bot(){ printf "%s└%s┘%s\n" "$C_MAGENTA" "$(line)" "$C_RESET"; }
box_ln(){ printf "%s│%s %-*s %s│%s\n" "$C_MAGENTA" "$C_RESET" "$W" "$1" "$C_MAGENTA" "$C_RESET"; }

banner(){
  cls
  cat <<'EOF'

 ______                 _____                      
|___  /                /  ___|                     
   / /  ___ _ __ ___   \ `--.  ___ ___  _ __   ___ 
  / /  / _ \ '__/ _ \   `--. \/ __/ _ \| '_ \ / _ \
./ /__|  __/ | | (_) | /\__/ / (_| (_) | |_) |  __/
\_____/\___|_|  \___/  \____/ \___\___/| .__/ \___|
                                       | |         
                                       |_|         

                  Hack The Planet

EOF
}

# ---------- State ----------
ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
OUT="${OUT:-$ROOT_DIR/out}"
RUN=""
STATE=""
DONE=""
EVID=""
LOGS=""
TARGETS=""
CONF=""
REPORT=""
AUTH_FILE=""

WORDLIST=""
RATE="10"
THREADS="50"
DEPTH="3"

AUTH_GATE_TEXT="This tool is for authorized security testing only.
Do you understand and agree to use it ethically and only with explicit permission?"

init_run(){
  mkdir -p "$OUT/run"
  RUN="$OUT/run"
  STATE="$RUN/state"
  DONE="$STATE/done"
  EVID="$RUN/evidence"
  LOGS="$RUN/logs"
  mkdir -p "$STATE" "$DONE" "$EVID" "$LOGS"
  TARGETS="$RUN/targets.txt"
  CONF="$RUN/modules.conf"
  REPORT="$RUN/REPORT.md"
  AUTH_FILE="$RUN/AUTHORIZATION.txt"
  touch "$TARGETS"
  ensure_conf
}

# ---------- Modules (IDs + descriptions) ----------
# You configure their commands in modules.conf
MODULE_IDS=(recon urls crawl params ffuf nuclei nmap report)
MODULE_TITLES=(
  "Recon"
  "URL Discovery"
  "Crawl"
  "Params"
  "ffuf"
  "Nuclei"
  "nmap"
  "Report"
)
MODULE_DESCS=(
  "Run your recon chain (subdomains/probe/etc.)."
  "Collect URLs (gau/wayback/etc.)."
  "Crawl targets (katana/etc.)."
  "Extract params, build candidate lists."
  "Run your fuzzing module."
  "Run your templates module."
  "Run your port scan module."
  "Build/update REPORT.md from evidence/logs."
)

# Selection state
SEL_recon=0
SEL_urls=0
SEL_crawl=0
SEL_params=0
SEL_ffuf=0
SEL_nuclei=0
SEL_nmap=0
SEL_report=0

reset_selection(){
  SEL_recon=0; SEL_urls=0; SEL_crawl=0; SEL_params=0
  SEL_ffuf=0; SEL_nuclei=0; SEL_nmap=0; SEL_report=0
}
toggle(){
  local name="$1"
  local v="${!name}"
  if [[ "$v" -eq 1 ]]; then
    printf -v "$name" "0"
  else
    printf -v "$name" "1"
  fi
}
sel_mark(){
  local v="$1"
  if [[ "$v" -eq 1 ]]; then
    printf "%s[x]%s" "$C_GREEN" "$C_RESET"
  else
    printf "%s[ ]%s" "$C_DIM" "$C_RESET"
  fi
}
sel_summary(){
  local s=""
  [[ "$SEL_recon" -eq 1 ]] && s="$s recon"
  [[ "$SEL_urls" -eq 1 ]] && s="$s urls"
  [[ "$SEL_crawl" -eq 1 ]] && s="$s crawl"
  [[ "$SEL_params" -eq 1 ]] && s="$s params"
  [[ "$SEL_ffuf" -eq 1 ]] && s="$s ffuf"
  [[ "$SEL_nuclei" -eq 1 ]] && s="$s nuclei"
  [[ "$SEL_nmap" -eq 1 ]] && s="$s nmap"
  [[ "$SEL_report" -eq 1 ]] && s="$s report"
  s="$(trim "$s")"
  [[ -z "$s" ]] && s="<none>"
  printf "%s" "$s"
}

# ---------- Targets ----------
normalize_target(){
  local x
  x="$(trim "$1")"
  x="$(printf "%s" "$x" | sed 's#^https\?://##g' | sed 's#/.*$##g' | sed 's/[[:space:]]//g')"
  x="$(lower "$x")"
  printf "%s" "$x"
}
targets_count(){ grep -c "." "$TARGETS" 2>/dev/null || echo 0; }
show_targets(){
  echo
  if [[ -s "$TARGETS" ]]; then
    nl -ba "$TARGETS"
  else
    echo "No targets saved."
  fi
}
targets_add(){
  echo
  echo "${C_DIM}Paste targets one per line. Blank line = finish. done = finish. b = back.${C_RESET}"
  echo
  while true; do
    printf "> "
    IFS= read -r line || true
    line="$(trim "$line")"
    local l
    l="$(lower "$line")"
    [[ "$l" == "b" ]] && return 0
    [[ -z "$line" ]] && break
    [[ "$l" == "done" ]] && break
    local t
    t="$(normalize_target "$line")"
    [[ -z "$t" ]] && continue
    echo "$t" >> "$TARGETS"
    printf "%s[+]%s %s\n" "$C_GREEN" "$C_RESET" "$t"
  done
  sort -u "$TARGETS" -o "$TARGETS"
  echo
  printf "%s[+]%s Saved: %s targets\n" "$C_GREEN" "$C_RESET" "$(targets_count)"
  show_targets
  echo
  pause
}
targets_clear(){
  : > "$TARGETS"
  printf "\n%s[+]%s Targets cleared\n" "$C_GREEN" "$C_RESET"
  pause
}
targets_menu(){
  while true; do
    banner
    box_top
    box_ln "${C_BOLD}Targets${C_RESET}"
    box_ln ""
    box_ln "Stored: ${C_CYAN}${TARGETS}${C_RESET}"
    box_ln ""
    box_ln "${C_YELLOW}1${C_RESET}) Add targets"
    box_ln "${C_YELLOW}2${C_RESET}) View targets"
    box_ln "${C_YELLOW}3${C_RESET}) Clear targets"
    box_ln "${C_YELLOW}b${C_RESET}) Back"
    box_bot
    printf "\n%sTargets:%s %s\n" "$C_DIM" "$C_RESET" "$(targets_count)"
    printf "\n%s> %s" "$C_BOLD" "$C_RESET"
    IFS= read -r c || true
    c="$(trim "$c")"
    case "$c" in
      1) targets_add ;;
      2) show_targets; echo; pause ;;
      3) targets_clear ;;
      b|B) return 0 ;;
      *) ;;
    esac
  done
}

