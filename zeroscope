  while true; do
    banner
    status_panel
    box_top
    box_ln "${C_BOLD}Scans${C_RESET}"
    box_ln ""
    box_ln "${C_YELLOW}1${C_RESET}) Nuclei (placeholder)"
    box_ln "${C_YELLOW}2${C_RESET}) ffuf (placeholder)"
