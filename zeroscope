  box_top
  box_ln "${C_BOLD}Session${C_RESET}"
  box_ln ""
  box_ln "Targets: ${C_CYAN}$(targets_count)${C_RESET}   Out: ${C_CYAN}${OUT}${C_RESET}"
  box_ln "Rate: ${C_CYAN}${RATE}${C_RESET}  Threads: ${C_CYAN}${THREADS}${C_RESET}  Depth: ${C_CYAN}${DEPTH}${C_RESET}"
