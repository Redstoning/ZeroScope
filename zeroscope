#!/usr/bin/env bash
set -euo pipefail

if command -v tput >/dev/null 2>&1; then
  C_RESET="$(tput sgr0)"; C_BOLD="$(tput bold)"; C_DIM="$(tput dim)"
  C_RED="$(tput setaf 1)"; C_GREEN="$(tput setaf 2)"; C_YELLOW="$(tput setaf 3)"
  C_BLUE="$(tput setaf 4)"; C_MAGENTA="$(tput setaf 5)"; C_CYAN="$(tput setaf 6)"
else
  C_RESET=""; C_BOLD=""; C_DIM=""
  C_RED=""; C_GREEN=""; C_YELLOW=""; C_BLUE=""; C_MAGENTA=""; C_CYAN=""
fi

cls() { printf "\033c"; }
pause() { printf "\n%sPress Enter to continue...%s" "$C_DIM" "$C_RESET"; IFS= read -r _; }
need() { command -v "$1" >/dev/null 2>&1 || return 1; }

box_top()    { printf "%s┌%s┐%s\n" "$C_MAGENTA" "$(printf '─%.0s' $(seq 1 70))" "$C_RESET"; }
box_bottom() { printf "%s└%s┘%s\n" "$C_MAGENTA" "$(printf '─%.0s' $(seq 1 70))" "$C_RESET"; }
box_line()   { printf "%s│%s %-70s %s│%s\n" "$C_MAGENTA" "$C_RESET" "$1" "$C_MAGENTA" "$C_RESET"; }

banner() {
  cls
  cat << "EOF"

 ______                 _____                      
|___  /                /  ___|                     
   / /  ___ _ __ ___   \ `--.  ___ ___  _ __   ___ 
  / /  / _ \ '__/ _ \   `--. \/ __/ _ \| '_ \ / _ \
./ /__|  __/ | | (_) | /\__/ / (_| (_) | |_) |  __/
\_____/\___|_|  \___/  \____/ \___\___/| .__/ \___|
                                       | |         
                                       |_|         

                  Hack The Planet

EOF
}

normalize_target() {
  echo "$1" \
    | sed 's/\r//g' \
    | sed 's#^https\?://##g' \
    | sed 's#/.*$##g' \
    | sed 's/[[:space:]]//g' \
    | tr 'A-Z' 'a-z'
}

OUT="out"
RUN=""
TARGETS_FILE=""
WORDLIST=""
RATE="10"
CONCURRENCY="50"
DEPTH="3"
NUCLEI_TAGS="misconfig,cves,default-logins,exposed-panels,takeovers"
SEVERITY="low,medium,high,critical"

init_run() {
  mkdir -p "$OUT/run"
  RUN="$OUT/run"
  TARGETS_FILE="$RUN/targets.txt"
  : > "$TARGETS_FILE"
  mkdir -p "$RUN/evidence"
}

deps_status() {
  local missing=0
  for c in rg jq subfinder dnsx httpx gau waybackurls katana nuclei ffuf nmap; do
    if need "$c"; then
      printf "%sOK%s  %s\n" "$C_GREEN" "$C_RESET" "$c"
    else
      printf "%sMISS%s %s\n" "$C_RED" "$C_RESET" "$c"
      missing=1
    fi
  done
  return "$missing"
}

targets_page() {
  while true; do
    banner
    box_top
    box_line "${C_BOLD}Targets${C_RESET} (no files to edit)"
    box_line ""
    box_line "Paste domains/hosts one per line. Blank line to finish."
    box_line "Examples: example.com  api.example.com"
    box_line ""
    box_line "${C_YELLOW}1${C_RESET}) Enter targets now"
    box_line "${C_YELLOW}2${C_RESET}) View current targets"
    box_line "${C_YELLOW}3${C_RESET}) Clear targets"
    box_line "${C_YELLOW}b${C_RESET}) Back"
    box_bottom

    local count
    count="$(wc -l < "$TARGETS_FILE" 2>/dev/null | tr -d ' ')"
    echo "${C_DIM}Current targets:${C_RESET} ${C_CYAN}${count}${C_RESET}   (${C_DIM}$TARGETS_FILE${C_RESET})"
    printf "\n%s> %s" "$C_BOLD" "$C_RESET"
    IFS= read -r c

    case "$c" in
      1)
        echo
        echo "${C_DIM}Paste targets now. Blank line to stop.${C_RESET}"
        while true; do
          printf "> "
          IFS= read -r line || true
          line="$(normalize_target "$line")"
          [[ -z "$line" ]] && break
          echo "$line" >> "$TARGETS_FILE"
        done
        sort -u "$TARGETS_FILE" -o "$TARGETS_FILE"
        ;;
      2)
        echo
        if [[ -s "$TARGETS_FILE" ]]; then
          nl -ba "$TARGETS_FILE"
        else
          echo "No targets yet."
        fi
        pause
        ;;
      3)
        : > "$TARGETS_FILE"
        ;;
      b|B) return 0 ;;
      *) ;;
    esac
  done
}

settings_page() {
  while true; do
    banner
    box_top
    box_line "${C_BOLD}Settings${C_RESET}"
    box_line ""
    box_line "Output: ${C_CYAN}${OUT}${C_RESET}"
    box_line "Rate: ${C_CYAN}${RATE}${C_RESET}   Concurrency: ${C_CYAN}${CONCURRENCY}${C_RESET}   Depth: ${C_CYAN}${DEPTH}${C_RESET}"
    box_line "Wordlist: ${C_CYAN}${WORDLIST:-<not set>}${C_RESET}"
    box_line "Nuclei tags: ${C_CYAN}${NUCLEI_TAGS}${C_RESET}"
    box_line "Severity: ${C_CYAN}${SEVERITY}${C_RESET}"
    box_line ""
    box_line "${C_YELLOW}1${C_RESET}) Output directory"
    box_line "${C_YELLOW}2${C_RESET}) Rate limit"
    box_line "${C_YELLOW}3${C_RESET}) Concurrency"
    box_line "${C_YELLOW}4${C_RESET}) Crawl depth"
    box_line "${C_YELLOW}5${C_RESET}) Wordlist path"
    box_line "${C_YELLOW}6${C_RESET}) Nuclei tags"
    box_line "${C_YELLOW}7${C_RESET}) Nuclei severity"
    box_line "${C_YELLOW}b${C_RESET}) Back"
    box_bottom
    printf "\n%s> %s" "$C_BOLD" "$C_RESET"
    IFS= read -r c
    case "$c" in
      1) printf "Out [%s]: " "$OUT"; IFS= read -r v; [[ -n "$v" ]] && OUT="$v"; init_run ;;
      2) printf "Rate [%s]: " "$RATE"; IFS= read -r v; [[ -n "$v" ]] && RATE="$v" ;;
      3) printf "Concurrency [%s]: " "$CONCURRENCY"; IFS= read -r v; [[ -n "$v" ]] && CONCURRENCY="$v" ;;
      4) printf "Depth [%s]: " "$DEPTH"; IFS= read -r v; [[ -n "$v" ]] && DEPTH="$v" ;;
      5) printf "Wordlist path (blank = unset): "; IFS= read -r v; WORDLIST="$v" ;;
      6) printf "Nuclei tags [%s]: " "$NUCLEI_TAGS"; IFS= read -r v; [[ -n "$v" ]] && NUCLEI_TAGS="$v" ;;
      7) printf "Severity [%s]: " "$SEVERITY"; IFS= read -r v; [[ -n "$v" ]] && SEVERITY="$v" ;;
      b|B) return 0 ;;
      *) ;;
    esac
  done
}

generate_runbook() {
  if [[ ! -s "$TARGETS_FILE" ]]; then
    echo "${C_RED}[!]${C_RESET} No targets set."
    pause
    return 1
  fi

  banner
  box_top
  box_line "${C_BOLD}Authorization gate${C_RESET}"
  box_line ""
  box_line "This generates a runbook for the targets you entered."
  box_line "Only proceed if you have explicit authorization."
  box_line ""
  box_bottom
  echo
  printf "%sType: I_HAVE_AUTHORIZATION > %s" "$C_BOLD" "$C_RESET"
  IFS= read -r ack
  if [[ "$ack" != "I_HAVE_AUTHORIZATION" ]]; then
    echo "${C_YELLOW}[!]${C_RESET} Cancelled."
    pause
    return 1
  fi

  local cmds="$RUN/COMMANDS.sh"
  local report="$RUN/REPORT.md"
  local now
  now="$(date -Is)"

  {
    echo "#!/usr/bin/env bash"
    echo "set -euo pipefail"
    echo
    echo "OUTDIR=\"$RUN\""
    echo "TARGETS=\"$TARGETS_FILE\""
    echo "RATE=\"$RATE\""
    echo "CONCURRENCY=\"$CONCURRENCY\""
    echo "DEPTH=\"$DEPTH\""
    echo "NUCLEI_TAGS=\"$NUCLEI_TAGS\""
    echo "SEVERITY=\"$SEVERITY\""
    echo "WORDLIST=\"${WORDLIST}\""
    echo
    echo "mkdir -p \"\$OUTDIR/evidence\""
    echo
    echo "echo \"[runbook] targets: \$TARGETS\""
    echo "echo \"[runbook] output:  \$OUTDIR\""
    echo
    echo "echo \"[1] subdomains (subfinder)\""
    echo "subfinder -silent -dL \"\$TARGETS\" -all -o \"\$OUTDIR/subs.txt\" || true"
    echo
    echo "echo \"[2] resolve (dnsx)\""
    echo "cat \"\$TARGETS\" \"\$OUTDIR/subs.txt\" 2>/dev/null | sed '/^$/d' | sort -u > \"\$OUTDIR/hosts.txt\""
    echo "dnsx -silent -l \"\$OUTDIR/hosts.txt\" -a -aaaa -resp -o \"\$OUTDIR/resolved.txt\" || true"
    echo "cut -d' ' -f1 \"\$OUTDIR/resolved.txt\" | sed '/^$/d' | sort -u > \"\$OUTDIR/resolved_hosts.txt\""
    echo
    echo "echo \"[3] probe (httpx)\""
    echo "httpx -silent -l \"\$OUTDIR/resolved_hosts.txt\" -title -tech-detect -status-code -content-length -server -location \\"
    echo "  -threads \"\$CONCURRENCY\" -rate-limit \"\$RATE\" -json -o \"\$OUTDIR/httpx.json\" || true"
    echo "jq -r 'select(.url!=null) | .url' \"\$OUTDIR/httpx.json\" 2>/dev/null | sed '/^$/d' | sort -u > \"\$OUTDIR/live_urls.txt\""
    echo "jq -r 'select(.host!=null) | .host' \"\$OUTDIR/httpx.json\" 2>/dev/null | sed '/^$/d' | sort -u > \"\$OUTDIR/live_hosts.txt\""
    echo
    echo "echo \"[4] urls (gau + waybackurls)\""
    echo "cat \"\$OUTDIR/live_hosts.txt\" | gau --subs 2>/dev/null | sed '/^$/d' | sort -u > \"\$OUTDIR/gau_urls.txt\" || true"
    echo "cat \"\$OUTDIR/live_hosts.txt\" | waybackurls 2>/dev/null | sed '/^$/d' | sort -u > \"\$OUTDIR/wayback_urls.txt\" || true"
    echo "cat \"\$OUTDIR/gau_urls.txt\" \"\$OUTDIR/wayback_urls.txt\" 2>/dev/null | sed '/^$/d' | sort -u > \"\$OUTDIR/urls_merged.txt\" || true"
    echo
    echo "echo \"[5] crawl (katana)\""
    echo "katana -silent -list \"\$OUTDIR/live_urls.txt\" -depth \"\$DEPTH\" -jc -jsl -kf -c \"\$CONCURRENCY\" -rl \"\$RATE\" \\"
    echo "  -o \"\$OUTDIR/katana_urls.txt\" || true"
    echo
    echo "echo \"[6] params\""
    echo "rg -n '\\?' \"\$OUTDIR/urls_merged.txt\" \"\$OUTDIR/katana_urls.txt\" 2>/dev/null | cut -d: -f2- | sed '/^$/d' | sort -u > \"\$OUTDIR/urls_params_all.txt\" || true"
    echo
    echo "echo \"[7] nuclei (optional)\""
    echo "nuclei -silent -l \"\$OUTDIR/live_urls.txt\" -tags \"\$NUCLEI_TAGS\" -severity \"\$SEVERITY\" -rl \"\$RATE\" -c \"\$CONCURRENCY\" \\"
    echo "  -jsonl -o \"\$OUTDIR/evidence/nuclei.jsonl\" || true"
    echo
    echo "echo \"[8] nmap (optional)\""
    echo "nmap -sV -sC -T4 --top-ports 200 -iL \"\$OUTDIR/live_hosts.txt\" -oN \"\$OUTDIR/evidence/nmap_top200.txt\" || true"
    echo
    echo "echo \"[9] ffuf (optional)\""
    echo "if [[ -n \"\$WORDLIST\" && -f \"\$WORDLIST\" ]]; then"
    echo "  mkdir -p \"\$OUTDIR/evidence/ffuf\""
    echo "  while read -r u; do"
    echo "    [[ -z \"\$u\" ]] && continue"
    echo "    hs=\$(echo \"\$u\" | sed 's#^https\\?://##g' | sed 's#/.*\$##g' | tr '/:?' '___')"
    echo "    ffuf -w \"\$WORDLIST\" -u \"\$u/FUZZ\" -t 30 -rate \"\$RATE\" -timeout 8 \\"
    echo "      -mc 200,204,301,302,307,308,401,403,405 -of json -o \"\$OUTDIR/evidence/ffuf/\${hs}.json\" >/dev/null 2>&1 || true"
    echo "  done < \"\$OUTDIR/live_urls.txt\""
    echo "else"
    echo "  echo \"[ffuf] wordlist not set; skipping\""
    echo "fi"
    echo
    echo "echo \"[done]\""
  } > "$cmds"

  chmod +x "$cmds"

  {
    echo "# ZeroScope Run"
    echo
    echo "- Generated: $now"
    echo "- Targets: $TARGETS_FILE"
    echo "- Output: $RUN"
    echo
    echo "## Next steps"
    echo "Run:"
    echo
    echo '```'
    echo "./COMMANDS.sh"
    echo '```'
    echo
    echo "## Evidence"
    echo "- httpx.json"
    echo "- live_urls.txt"
    echo "- urls_params_all.txt"
    echo "- evidence/nuclei.jsonl"
    echo "- evidence/nmap_top200.txt"
    echo "- evidence/ffuf/*.json"
  } > "$report"

  {
    echo "Generated at: $now"
    echo "User acknowledged authorization phrase."
    echo "Targets:"
    cat "$TARGETS_FILE"
  } > "$RUN/AUTHORIZATION.txt"

  echo "${C_GREEN}[+]${C_RESET} Generated:"
  echo "  ${C_CYAN}$cmds${C_RESET}"
  echo "  ${C_CYAN}$report${C_RESET}"
  pause
}

doctor_page() {
  banner
  box_top
  box_line "${C_BOLD}Doctor${C_RESET} (dependency check)"
  box_line ""
  box_bottom
  echo
  deps_status || true
  pause
}

main_menu() {
  init_run
  while true; do
    banner
    box_top
    box_line "${C_BOLD}ZeroScope${C_RESET} (guided runbook generator)"
    box_line ""
    box_line "${C_YELLOW}1${C_RESET}) Targets"
    box_line "${C_YELLOW}2${C_RESET}) Settings"
    box_line "${C_YELLOW}3${C_RESET}) Doctor"
    box_line "${C_YELLOW}4${C_RESET}) Generate Runbook (COMMANDS.sh)"
    box_line "${C_YELLOW}q${C_RESET}) Quit"
    box_bottom

    local count
    count="$(wc -l < "$TARGETS_FILE" 2>/dev/null | tr -d ' ')"
    echo "${C_DIM}Targets:${C_RESET} ${C_CYAN}${count}${C_RESET}   Out: ${C_CYAN}${OUT}${C_RESET}"
    printf "\n%s> %s" "$C_BOLD" "$C_RESET"
    IFS= read -r c
    case "$c" in
      1) targets_page ;;
      2) settings_page ;;
      3) doctor_page ;;
      4) generate_runbook ;;
      q|Q) exit 0 ;;
      *) ;;
    esac
  done
}

main_menu
