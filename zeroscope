# -------------------------
# Main loop
# -------------------------
main_menu() {
  local selected=""
  while true; do
    banner
    print_status
    print_menu

    if [[ -n "$selected" ]]; then
      echo "${C_DIM}Selected:${C_RESET} $selected"
    fi

    printf "\n%sChoose modules (e.g. 2 3 6), or s/r/q > %s" "$C_BOLD" "$C_RESET"
    IFS= read -r input
    input="$(echo "$input" | tr -s ' ' | sed 's/^ //; s/ $//')"

    case "$input" in
      q|Q) exit 0 ;;
      s|S) settings_menu ;;
      r|R)
        if [[ -z "$selected" ]]; then
          echo "${C_YELLOW}[!]${C_RESET} No selection buffer. Type numbers (e.g. 2 3 6) first."
          pause
          continue
        fi
        apply_selection_buffer "$selected"
        confirm_and_run
        ;;
      "")
        continue
        ;;
      *)
        if [[ "$input" =~ ^[0-9]+$ ]]; then
          open_page_for_number "$input"
        else
          selected="$input"
        fi
        ;;
    esac
  done
}

