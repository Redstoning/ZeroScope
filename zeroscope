edit_cmd(){
  local key="$1"
  local title="$2"
  local cur
  cur="$(conf_get "$key")"
  banner
  status_panel
  box_top
  box_ln "${C_BOLD}${title} Command${C_RESET}"
  box_ln ""
  box_ln "Enter a one-line command string."
  box_ln "Leave blank to keep unchanged."
  box_ln ""
  box_ln "Variables: {TARGETS} {OUT} {EVID} {LOGS} {WORDLIST} {RATE} {THREADS} {DEPTH}"
  box_ln ""
  box_bot
  echo
  printf "%sCurrent:%s %s\n\n" "$C_DIM" "$C_RESET" "${cur:-<unset>}"
  printf "%sNew> %s" "$C_BOLD" "$C_RESET"
  IFS= read -r v || true
  v="$(trim "$v")"
  if [[ -n "$v" ]]; then
    conf_set "$key" "$v"
    printf "\n%s[+]%s Saved.\n" "$C_GREEN" "$C_RESET"
  else
    printf "\n%s[~]%s Unchanged.\n" "$C_DIM" "$C_RESET"
  fi
  pause
}

# ---------- Report scaffolding ----------
ensure_report(){
  if [[ ! -f "$REPORT" ]]; then
    {
      echo "# ZeroScope Report"
      echo
      echo "## Targets"
      echo
      if [[ -s "$TARGETS" ]]; then
        while read -r t; do
          [[ -z "$t" ]] && continue
          echo "- $t"
        done < "$TARGETS"
      else
        echo "- (none)"
      fi
      echo
      echo "## Evidence"
      echo
      echo "- Logs: \`logs/\`"
      echo "- Evidence: \`evidence/\`"
      echo
      echo "## Hosts"
      echo
      if [[ -s "$TARGETS" ]]; then
        while read -r t; do
          [[ -z "$t" ]] && continue
          echo "### $t"
          echo
          echo "- Evidence folder: \`evidence/$t/\`"
          echo
        done < "$TARGETS"
      fi
    } > "$REPORT"
  fi
}

ensure_host_dirs(){
  if [[ -s "$TARGETS" ]]; then
    while read -r t; do
      [[ -z "$t" ]] && continue
      mkdir -p "$EVID/$t"
    done < "$TARGETS"
  fi
}

write_auth_log(){
  {
    echo "Ethics gate accepted at: $(date -Is)"
    echo
    echo "Targets:"
    cat "$TARGETS"
    echo
    echo "Selected: $(sel_summary)"
  } > "$AUTH_FILE"
}

# ---------- Streaming runner ----------
run_stream(){
  local title="$1"
  local logfile="$2"
  shift 2

  mkdir -p "$(dirname "$logfile")"
  : >> "$logfile"

  printf "%s[run]%s  %s\n" "$C_CYAN" "$C_RESET" "$title"
  printf "%s[log]%s  %s\n\n" "$C_DIM" "$C_RESET" "$logfile"

  set +e
  if command -v stdbuf >/dev/null 2>&1; then
    stdbuf -oL -eL "$@" 2>&1 | tee -a "$logfile"
    rc=${PIPESTATUS[0]}
  else
    "$@" 2>&1 | tee -a "$logfile"
    rc=${PIPESTATUS[0]}
  fi
  set -e

  echo
  if [[ "$rc" -eq 0 ]]; then
    printf "%s[+]%s %s finished\n" "$C_GREEN" "$C_RESET" "$title"
  else
    printf "%s[!]%s %s exited (%s)\n" "$C_YELLOW" "$C_RESET" "$title" "$rc"
  fi
  return "$rc"
}

module_cmd_key(){
  case "$1" in
    recon) echo "RECON_CMD" ;;
    urls) echo "URLS_CMD" ;;
    crawl) echo "CRAWL_CMD" ;;
    params) echo "PARAMS_CMD" ;;
    ffuf) echo "FFUF_CMD" ;;
    nuclei) echo "NUCLEI_CMD" ;;
    nmap) echo "NMAP_CMD" ;;
    report) echo "REPORT_CMD" ;;
    *) echo "" ;;
  esac
}

run_module(){
  local id="$1"
  local title="$2"

  if is_done "$id"; then
    printf "%s[skip]%s %s (resume)\n" "$C_DIM" "$C_RESET" "$title"
    return 0
  fi

  local key
  key="$(module_cmd_key "$id")"
  if [[ -z "$key" ]]; then
    printf "%s[!]%s Unknown module: %s\n" "$C_YELLOW" "$C_RESET" "$id"
    return 1
  fi

  local raw
  raw="$(conf_get "$key")"
  raw="$(trim "$raw")"

  if [[ -z "$raw" ]]; then
    printf "%s[!]%s %s not configured (set %s in Module Config)\n" "$C_YELLOW" "$C_RESET" "$title" "$key"
    return 1
  fi

  local cmd
  cmd="$(subst_vars "$raw")"

  local outdir="$EVID/_${id}"
  mkdir -p "$outdir"
  local logfile="$LOGS/${id}.log"

  run_stream "$title" "$logfile" bash -lc "$cmd"
  mark_done "$id"
}

run_selected(){
  if [[ "$(targets_count)" -eq 0 ]]; then
    printf "\n%s[!]%s Add targets first.\n" "$C_YELLOW" "$C_RESET"
    pause
    return 1
  fi
  if [[ "$(sel_summary)" == "<none>" ]]; then
    printf "\n%s[!]%s Select at least one module.\n" "$C_YELLOW" "$C_RESET"
    pause
    return 1
  fi
  if ! ethics_gate; then
    return 0
  fi

  ensure_host_dirs
  ensure_report
  write_auth_log

  banner
  status_panel
  box_top
  box_ln "${C_BOLD}Running Selected Modules${C_RESET}"
  box_ln ""
  box_ln "Resume is ON. Completed modules will be skipped."
  box_ln "Selected: $(sel_summary)"
  box_ln ""
  box_bot
  echo

  local failed=0
  [[ "$SEL_recon" -eq 1 ]] && run_module "recon" "Recon" || true
  [[ "$SEL_urls" -eq 1 ]] && run_module "urls" "URL Discovery" || true
  [[ "$SEL_crawl" -eq 1 ]] && run_module "crawl" "Crawl" || true
  [[ "$SEL_params" -eq 1 ]] && run_module "params" "Params" || true
  [[ "$SEL_ffuf" -eq 1 ]] && run_module "ffuf" "ffuf" || true
  [[ "$SEL_nuclei" -eq 1 ]] && run_module "nuclei" "Nuclei" || true
  [[ "$SEL_nmap" -eq 1 ]] && run_module "nmap" "nmap" || true
  [[ "$SEL_report" -eq 1 ]] && run_module "report" "Report" || true

  echo
  printf "%s[+]%s Done.\n" "$C_GREEN" "$C_RESET"
  printf "%sReport:%s %s\n" "$C_DIM" "$C_RESET" "$REPORT"
  printf "%sLogs:%s   %s\n" "$C_DIM" "$C_RESET" "$LOGS/"
  printf "%sEvid:%s   %s\n" "$C_DIM" "$C_RESET" "$EVID/"
  pause
}

modules_menu(){
  while true; do
    banner
    status_panel
    box_top
    box_ln "${C_BOLD}Modules${C_RESET}"
    box_ln ""
    box_ln "1) $(sel_mark "$SEL_recon") Recon"
    box_ln "2) $(sel_mark "$SEL_urls") URL Discovery"
    box_ln "3) $(sel_mark "$SEL_crawl") Crawl"
    box_ln "4) $(sel_mark "$SEL_params") Params"
    box_ln "5) $(sel_mark "$SEL_ffuf") ffuf"
    box_ln "6) $(sel_mark "$SEL_nuclei") Nuclei"
    box_ln "7) $(sel_mark "$SEL_nmap") nmap"
    box_ln "8) $(sel_mark "$SEL_report") Report"
    box_ln ""
    box_ln "${C_YELLOW}r${C_RESET}) Run selected"
    box_ln "${C_YELLOW}c${C_RESET}) Clear selection"
    box_ln "${C_YELLOW}x${C_RESET}) Reset resume state"
    box_ln "${C_YELLOW}b${C_RESET}) Back"
    box_bot

    printf "\n%sSelected:%s %s\n" "$C_DIM" "$C_RESET" "$(sel_summary)"
    printf "\n%s> %s" "$C_BOLD" "$C_RESET"
    IFS= read -r c || true
    c="$(trim "$c")"
    case "$c" in
      1) toggle SEL_recon ;;
      2) toggle SEL_urls ;;
      3) toggle SEL_crawl ;;
      4) toggle SEL_params ;;
      5) toggle SEL_ffuf ;;
      6) toggle SEL_nuclei ;;
      7) toggle SEL_nmap ;;
      8) toggle SEL_report ;;
      r|R) run_selected ;;
      c|C) reset_selection ;;
      x|X) reset_resume; printf "\n%s[+]%s Resume state reset.\n" "$C_GREEN" "$C_RESET"; pause ;;
      b|B) return 0 ;;
      *) ;;
    esac
  done
}

